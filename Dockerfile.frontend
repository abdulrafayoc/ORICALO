# Use specific Node.js version
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY frontend/package.json ./
COPY frontend/package-lock.json* ./

# Install dependencies
RUN npm install

# Copy application files
COPY frontend/ ./

# Build Next.js application
RUN npm run build

# Expose port
EXPOSE 3000

# Start application
CMD ["npm", "start"]
